{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/turn_map.schema.json",
  "title": "Orchestrator workflow turn map",
  "description": "Documents high-level turns (orchestrator state + active_loop) and per-step contracts. Conditions are human-readable; code is authoritative.",
  "type": "object",
  "required": ["flow_id", "version", "main_turns", "step_details"],
  "additionalProperties": false,
  "properties": {
    "flow_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "title": { "type": "string" },
    "authority": {
      "type": "string",
      "description": "Primary code path that implements transitions"
    },
    "related_specs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "entry_points": {
      "type": "array",
      "items": { "$ref": "#/definitions/entryPoint" }
    },
    "main_turns": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/mainTurn" }
    },
    "step_details": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/definitions/stepDetail" }
    }
  },
  "definitions": {
    "entryPoint": {
      "type": "object",
      "required": ["id", "first_turn_id"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "first_turn_id": { "type": "string" },
        "intent": { "type": "string" },
        "payload": { "type": "string" },
        "note": { "type": "string" },
        "guards": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sets_slots": { "type": "object" }
      }
    },
    "edge": {
      "type": "object",
      "required": ["when", "next_turn_id"],
      "additionalProperties": false,
      "properties": {
        "when": {
          "type": "string",
          "description": "Human-readable guard; must match code review"
        },
        "next_turn_id": { "type": "string" },
        "orchestrator_next_state": {
          "type": "string",
          "description": "Value returned as next_state when entering that turn"
        },
        "active_loop": {
          "type": "string",
          "description": "session.active_loop after transition"
        },
        "slot_effects": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "mainTurn": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "summary": { "type": "string" },
        "orchestrator_state": {
          "type": "string",
          "description": "Typical run_flow_turn state key while user is in this turn"
        },
        "active_loop": { "type": "string" },
        "edges_on_complete": {
          "type": "array",
          "items": { "$ref": "#/definitions/edge" }
        },
        "edges_on_intent": {
          "type": "array",
          "items": { "$ref": "#/definitions/edge" }
        },
        "terminal": { "type": "boolean" }
      }
    },
    "stepDetail": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "purpose": { "type": "string" },
        "slots_collected": {
          "type": "array",
          "items": { "type": "string" }
        },
        "slots_runtime_note": {
          "type": "string",
          "description": "e.g. required_slots from Python validators, not domain.yml"
        },
        "guards": {
          "type": "array",
          "items": { "type": "string" }
        },
        "side_effects": {
          "type": "array",
          "items": { "type": "string" }
        },
        "actions_invoked": {
          "type": "array",
          "items": { "type": "string" }
        },
        "code_refs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}

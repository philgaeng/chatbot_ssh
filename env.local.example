# Copy to env.local and fill in values. env.local is gitignored.
#
# Option B (project Redis): launch_servers_celery.sh starts Redis from scripts/local/redis.conf.
# Set REDIS_PASSWORD to the same value as requirepass in scripts/local/redis.conf.

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<same as requirepass in scripts/local/redis.conf>

ENABLE_CELERY_CLASSIFICATION=1

# Add other vars as needed (POSTGRES_*, FLASK_*, etc.).
